# sslctlw 远程发布配置
# 复制为 release.conf 并填写实际值
# 重要：设置文件权限 chmod 600 release.conf

# ========================================
# 服务器配置
# ========================================
# 格式: "名称,主机,端口,目录"
# - 名称: 服务器标识，用于 --server 参数
# - 主机: SSH 主机地址
# - 端口: SSH 端口（默认 22）
# - 目录: 远程发布目录

SERVERS=(
    "cn,release1.example.com,22,/var/www/release/sslctlw"
    "us,release2.example.com,22,/var/www/release/sslctlw"
)

# ========================================
# SSH 认证
# ========================================
SSH_USER="release"
SSH_KEY="~/.ssh/release"

# ========================================
# 可选配置
# ========================================
# 每个通道保留的版本数量（默认 5）
# KEEP_VERSIONS=5

# SSH 连接超时秒数（默认 10）
# SSH_TIMEOUT=10
